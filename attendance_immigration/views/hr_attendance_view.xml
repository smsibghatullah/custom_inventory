<odoo>

    <!-- Tree View -->
    <record id="view_attendance_tree_inherit_immigration" model="ir.ui.view">
        <field name="name">hr.attendance.tree.immigration</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='worked_hours']" position="replace">

                <!-- Admin (sab dekhe) -->
                <field name="worked_hours" widget="float_time"
                    groups="base.group_system"/>
                <field name="immigration_submitted_hrs" widget="float_time"
                    groups="base.group_system"/>
                <field name="immigration_rate"
                    groups="base.group_system"/>

                <!-- Normal users -->
                <field name="worked_hours" widget="float_time"
                    groups="!attendance_immigration.group_show_immigration,!base.group_system"/>

                <!-- Immigration users -->
                <field name="immigration_submitted_hrs" widget="float_time"
                    groups="attendance_immigration.group_show_immigration,!base.group_system"/>
                <field name="immigration_rate"
                    groups="attendance_immigration.group_show_immigration,!base.group_system"/>

            </xpath>

            <xpath expr="//field[@name='approved_hours']" position="replace">

                <!-- Admin -->
                <field name="approved_hours" widget="float_time"
                    groups="base.group_system"/>
                <field name="immigration_approved_hrs" widget="float_time"
                    groups="base.group_system"/>

                <!-- Normal -->
                <field name="approved_hours" widget="float_time"
                    groups="!attendance_immigration.group_show_immigration,!base.group_system"/>

                <!-- Immigration -->
                <field name="immigration_approved_hrs" widget="float_time"
                    groups="attendance_immigration.group_show_immigration,!base.group_system"/>

            </xpath>

        </field>
    </record>

    <!-- Form View -->
    <record id="view_attendance_form_inherit_immigration" model="ir.ui.view">
        <field name="name">hr.attendance.form.immigration</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">

            <!-- Worked Hours -->
            <xpath expr="//field[@name='worked_hours']" position="replace">

                <!-- Admin (sab dekhe) -->
                <field name="worked_hours" widget="float_time" groups="base.group_system"/>
                <field name="immigration_submitted_hrs" widget="float_time" groups="base.group_system"/>

                <!-- Normal users -->
                <field name="worked_hours" widget="float_time"
                    groups="!attendance_immigration.group_show_immigration,!base.group_system"/>

                <!-- Immigration users -->
                <field name="immigration_submitted_hrs" widget="float_time"
                    groups="attendance_immigration.group_show_immigration,!base.group_system"/>

            </xpath>

            <!-- Approved Hours -->
            <xpath expr="//field[@name='approved_hours']" position="replace">

                <!-- Admin -->
                <field name="approved_hours" widget="float_time" groups="base.group_system"/>
                <field name="immigration_approved_hrs" widget="float_time" groups="base.group_system"/>

                <!-- Normal -->
                <field name="approved_hours" widget="float_time"
                    groups="!attendance_immigration.group_show_immigration,!base.group_system"/>

                <!-- Immigration -->
                <field name="immigration_approved_hrs" widget="float_time"
                    groups="attendance_immigration.group_show_immigration,!base.group_system"/>

            </xpath>

            <!-- Immigration Info -->
            <xpath expr="//sheet" position="inside">
                <group string="Immigration Info"
                    groups="attendance_immigration.group_show_immigration,base.group_system">
                    <field name="currency_id" invisible="1"/>
                    <field name="immigration_rate"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>