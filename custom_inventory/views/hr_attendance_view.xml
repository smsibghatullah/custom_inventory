<odoo>
  <!-- Form View -->
  <record id="view_hr_attendance_form_inherit_custom" model="ir.ui.view">
    <field name="name">hr.attendance.form.custom</field>
    <field name="model">hr.attendance</field>
    <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
    <field name="arch" type="xml">

      <xpath expr="//sheet" position="before">
        <header>
         <button name="action_approve_attendance"
                  string="Approve"
                  type="object"
                  class="btn-primary"
                  groups="custom_inventory.group_create_access"
                  invisible="status == 'approved'"/>
          <field name="status" widget="statusbar" statusbar_visible="submitted,approved"/>
        </header>
      </xpath>

      <xpath expr="//field[@name='worked_hours']" position="attributes">
        <attribute name="string">Submit Hours</attribute>
      </xpath>
      <xpath expr="//field[@name='check_out']" position="after">
        <field name="comment" />
        <field name="notes" />
      </xpath>
      <xpath expr="//field[@name='worked_hours']" position="after">
        <field name="approved_hours" widget="float_time"/>
      </xpath>

      <xpath expr="//field[@name='overtime_hours']" position="after">
        <field name="break_time"/>
        <field name="date_time"/>
      </xpath>

    </field>
  </record>

  <record id="view_hr_attendance_tree_inherit_custom" model="ir.ui.view">
    <field name="name">hr.attendance.tree.custom</field>
    <field name="model">hr.attendance</field>
    <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
    <field name="arch" type="xml">

      <xpath expr="//tree" position="inside">
            <header>
                <button
                    name="action_export_attendance_csv"
                    type="object"
                    string="Export CSV"
                    class="btn-primary"
                />
            </header>
        </xpath>

      <xpath expr="//field[@name='worked_hours']" position="attributes">
        <attribute name="string">Submit Hours</attribute>
      </xpath>

      <xpath expr="//field[@name='worked_hours']" position="before">
        <field name="comment"/>
      </xpath>

      <xpath expr="//field[@name='worked_hours']" position="after">
        <field name="approved_hours" widget="float_time"/>
      </xpath>

      <xpath expr="//field[@name='overtime_hours']" position="after">
        <field name="status" widget="badge"/>
      </xpath>

    </field>
  </record>



    <!-- Search View -->
    <record id="view_my_employee_attendance_search" model="ir.ui.view">
        <field name="name">hr.attendance.my.employee.search</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <search string="My Employees Attendance">
                <field name="employee_id"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="status"/>

                <filter name="today"
                        string="Today"
                        domain="[('check_in', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')),
                                 ('check_in', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>

                <filter name="submitted"
                        string="Submitted"
                        domain="[('status', '=', 'submitted')]"/>

                <filter name="approved"
                        string="Approved"
                        domain="[('status', '=', 'approved')]"/>

                <group expand="0" string="Group By">
                    <filter name="group_employee"
                            string="Employee"
                            context="{'group_by': 'employee_id'}"/>

                    <filter name="group_status"
                            string="Status"
                            context="{'group_by': 'status'}"/>

                    <filter name="group_check_in"
                            string="Check In Date"
                            context="{'group_by': 'check_in'}"/>
                </group>
            </search>
        </field>
    </record>


</odoo>
