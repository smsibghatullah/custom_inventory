<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="server_action_open_my_allowed_attendance" model="ir.actions.server">
            <field name="name">My Allowed Employee Attendances</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="state">code</field>
            <field name="code">action = model.action_open_my_allowed_attendance()</field>
        </record>

        <menuitem
            id="menu_my_allowed_employee_attendance"
            name="Attendance Dashboard"
            parent="hr_attendance.menu_hr_attendance_root"
            action="server_action_open_my_allowed_attendance"
            sequence="10"
            groups="base.group_user"
        />

         <record id="hr_attendance.menu_hr_attendance_view_attendances" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>

    </data>
</odoo>
