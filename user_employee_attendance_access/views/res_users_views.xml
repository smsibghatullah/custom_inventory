<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_users_form_attendance_employee_ids" model="ir.ui.view">
            <field name="name">res.users.form.attendance.employee.ids</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='access_rights']"
                   position="after">

                <page string="Attendance Employees">

                    <group>
                        <field
                            name="employee_ids"
                            widget="many2many_tags"
                            domain="[]"
                            context="{'active_test': False, 'allowed_company_ids': []}"
                            options="{'no_create': True, 'no_open': False}"
                            placeholder="Select employees from any company..."
                        />
                    </group>

                </page>

            </xpath>
            </field>
        </record>

    </data>
</odoo>
